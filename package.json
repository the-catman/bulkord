{
    "name": "bulkord",
    "version": "1.0.0",
    "description": "Bulk Discord message search and delete tool",
    "main": "electron/app.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win",
        "postinstall": "electron-builder install-app-deps",
        "cli": "node cli.js"
    },
    "dependencies": {
        "better-sqlite3": "^12.10.0",
        "json-bigint": "^1.0.0"
    },
    "devDependencies": {
        "electron": "^40.0.1",
        "electron-builder": "^26.8.1"
    },
    "build": {
        "appId": "com.bulkord.app",
        "productName": "Bulkord",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "electron/**/*",
            "renderer/**/*",
            "lib/**/*"
        ],
        "win": {
            "target": "portable"
        },
        "portable": {
            "artifactName": "Bulkord.exe"
        }
    }
}
